@model PokerTracker.ViewModels.Tournaments.TournamentFilterViewModel

@{
    ViewData["Title"] = "All Tournaments";
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Poker Tournaments</h1>
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <a asp-action="Add" class="btn btn-success btn-lg shadow-sm">
                <i class="bi bi-plus-circle"></i> Create New
            </a>
        }
    </div>

    <div class="card shadow-sm border-0 mb-4 rounded-4">
        <div class="card-body p-4 bg-white">
            <form method="get" class="row g-3 align-items-end">

                <div class="col-lg-3 col-md-6">
                    <label class="form-label fw-bold text-secondary small mb-2 text-uppercase" style="letter-spacing: 0.5px;">Search</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-muted">
                            <i class="bi bi-search"></i>
                        </span>
                        <input asp-for="SearchTerm" class="form-control bg-light border-start-0" placeholder="Search by name...">
                    </div>
                </div>

                <div class="col-lg-2 col-md-3">
                    <label class="form-label fw-bold text-secondary small mb-2 text-uppercase" style="letter-spacing: 0.5px;">Format</label>
                    <select asp-for="FormatId" class="form-select bg-light border-0 py-2">
                        <option value="">All Formats</option>
                        @foreach (var format in Model.Formats)
                        {
                            <option value="@format.Id">@format.Name</option>
                        }
                    </select>
                </div>

                <div class="col-lg-2 col-md-3">
                    <label class="form-label fw-bold text-secondary small mb-2 text-uppercase" style="letter-spacing: 0.5px;">Status</label>
                    <select asp-for="Status" class="form-select bg-light border-0 py-2">
                        <option value="">All Statuses</option>
                        <option value="Open">Open</option>
                        <option value="Running">Running</option>
                        <option value="Finished">Finished</option>
                    </select>
                </div>

                <div class="col-lg-2 col-md-6">
                    <label class="form-label fw-bold text-secondary small mb-2 text-uppercase" style="letter-spacing: 0.5px;">Sort By</label>
                    <select asp-for="SortOrder" class="form-select bg-light border-0 py-2">
                        <option value="@PokerTracker.GCommon.ApplicationConstants.SortOrders.StatusDefault">Status</option>
                        <option value="@PokerTracker.GCommon.ApplicationConstants.SortOrders.DateAscending">Date (Oldest)</option>
                        <option value="@PokerTracker.GCommon.ApplicationConstants.SortOrders.DateDescending">Date (Newest)</option>
                        <option value="@PokerTracker.GCommon.ApplicationConstants.SortOrders.NameAscending">Name (A-Z)</option>
                    </select>
                </div>

                    <div class="col-lg-1 col-md-2 pb-2">
                        <div class="form-check form-switch m-0">
                            <input class="form-check-input shadow-none" type="checkbox" asp-for="OnlyJoined" id="joinedCheck">
                            <label class="form-check-label fw-bold text-secondary small" for="joinedCheck">
                                Joined
                            </label>
                        </div>
                    </div>

                <div class="col-lg-1 col-md-2 pb-2">
                    <div class="form-check form-switch m-0">
                        <input class="form-check-input shadow-none" type="checkbox" asp-for="OnlyOwned" id="ownedCheck">
                        <label class="form-check-label fw-bold text-secondary small" for="ownedCheck">
                            Owned
                        </label>
                    </div>
                </div>

                <div class="col-lg-2 col-md-6">
                    <div class="d-flex gap-2 h-100">
                        <button type="submit" class="btn btn-primary fw-bold flex-grow-1 shadow-sm py-2">
                            <i class="bi bi-funnel-fill me-2"></i>Filter
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center justify-content-center px-3 shadow-sm border-light-subtle" title="Reset">
                            <i class="bi bi-arrow-counterclockwise"></i>
                        </a>
                    </div>
                </div>

            </form>
        </div>
    </div>
    @if (!Model.Tournaments.Any())
    {
        <div class="alert alert-info text-center">
            <h4>No tournaments found!</h4>
            <p>Try adjusting your filters or be the first to create one.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var tournament in Model.Tournaments)
            {
                <partial name="_TournamentCardPartial" model="tournament" />
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Tournaments pagination" class="mt-4">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" 
                           asp-route-pageNumber="@(Model.CurrentPage - 1)"
                           asp-route-searchTerm="@Model.SearchTerm"
                           asp-route-formatId="@Model.FormatId"
                           asp-route-status="@Model.Status"
                           asp-route-sortOrder="@Model.SortOrder"
                           asp-route-onlyJoined="@Model.OnlyJoined"
                           asp-route-onlyOwned="@Model.OnlyOwned">Previous</a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        if (i == 1 || i == Model.TotalPages || (i >= Model.CurrentPage - 2 && i <= Model.CurrentPage + 2))
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="Index" 
                                   asp-route-pageNumber="@i"
                                   asp-route-searchTerm="@Model.SearchTerm"
                                   asp-route-formatId="@Model.FormatId"
                                   asp-route-status="@Model.Status"
                                   asp-route-sortOrder="@Model.SortOrder"
                                   asp-route-onlyJoined="@Model.OnlyJoined"
                                   asp-route-onlyOwned="@Model.OnlyOwned">@i</a>
                            </li>
                        }
                        else if (i == Model.CurrentPage - 3 || i == Model.CurrentPage + 3)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                    }
                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" 
                           asp-route-pageNumber="@(Model.CurrentPage + 1)"
                           asp-route-searchTerm="@Model.SearchTerm"
                           asp-route-formatId="@Model.FormatId"
                           asp-route-status="@Model.Status"
                           asp-route-sortOrder="@Model.SortOrder"
                           asp-route-onlyJoined="@Model.OnlyJoined"
                           asp-route-onlyOwned="@Model.OnlyOwned">Next</a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>