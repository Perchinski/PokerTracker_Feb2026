@{
    ViewData["Title"] = "400 - Bad Request";
}

<div class="container d-flex justify-content-center align-items-center mt-5 pt-4">
    <div class="text-center p-5 bg-dark border border-secondary rounded shadow-lg" style="max-width: 650px;">

        <div class="mb-2 display-3 text-secondary">
            <i class="bi bi-sign-stop-fill"></i>
        </div>

        <h1 class="display-1 fw-bold text-secondary mb-0" style="text-shadow: 2px 2px 8px rgba(0,0,0,0.8); letter-spacing: 5px;">
            400
        </h1>
        <h2 class="display-6 text-white fw-bold mb-4">String Bet!</h2>

        <hr class="border-secondary opacity-75 w-75 mx-auto mb-4" />

        <p class="lead text-light fs-3 mb-2 fw-semibold">
            That is an illegal move at this table.
        </p>
        <p class="text-white-50 fs-5 mb-5 px-3">
            The dealer didn't understand your request. Your browser sent a malformed bet or missing data that the server couldn't process. Take your chips back and try again.
        </p>

        <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-secondary btn-lg px-5 py-3 fw-bold rounded-pill shadow-sm text-dark">
            <i class="bi bi-arrow-return-left me-2"></i> Take Your Chips Back
        </a>

    </div>
</div>