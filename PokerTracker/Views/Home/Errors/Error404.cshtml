@{
    ViewData["Title"] = "404 - Folded Pre-Flop";
}

<div class="container d-flex justify-content-center align-items-center mt-5 pt-4">
    <div class="text-center p-5 bg-dark border border-warning rounded shadow-lg" style="max-width: 650px;">

        <div class="mb-2 d-flex justify-content-center gap-4 display-4">
            <span class="text-light">&spades;</span>
            <span class="text-danger">&hearts;</span>
            <span class="text-light">&clubs;</span>
            <span class="text-danger">&diams;</span>
        </div>

        <h1 class="display-1 fw-bold text-warning mb-0" style="text-shadow: 2px 2px 8px rgba(0,0,0,0.8); letter-spacing: 5px;">
            404
        </h1>
        <h2 class="display-6 text-white fw-bold mb-4">Dead Man's Hand!</h2>

        <hr class="border-warning opacity-75 w-75 mx-auto mb-4" />

        <p class="lead text-light fs-3 mb-2 fw-semibold">
            You bluffed, and the server called.
        </p>
        <p class="text-white-50 fs-5 mb-5 px-3">
            Looks like you pushed all-in on a busted draw. The page you're hunting for folded pre-flop, got lost in the shuffle, or simply isn't in the deck anymore.
        </p>

        <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-warning btn-lg px-5 py-3 fw-bold rounded-pill shadow-sm">
            <i class="bi bi-box-arrow-in-left me-2"></i> Return to the Lobby
        </a>

    </div>
</div>