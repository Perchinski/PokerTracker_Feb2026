@{
    ViewData["Title"] = "500 - Complete Misdeal";
}

<div class="container d-flex justify-content-center align-items-center mt-5 pt-4">
    <div class="text-center p-5 bg-dark border border-danger rounded shadow-lg" style="max-width: 650px;">

        <div class="mb-2 display-3 text-danger">
            <i class="bi bi-exclamation-triangle-fill"></i>
        </div>

        <h1 class="display-1 fw-bold text-danger mb-0" style="text-shadow: 2px 2px 8px rgba(0,0,0,0.8); letter-spacing: 5px;">
            500
        </h1>
        <h2 class="display-6 text-white fw-bold mb-4">Complete Misdeal!</h2>

        <hr class="border-danger opacity-75 w-75 mx-auto mb-4" />

        <p class="lead text-light fs-3 mb-2 fw-semibold">
            The server just went on full tilt.
        </p>
        <p class="text-white-50 fs-5 mb-5 px-3">
            Someone spilled a drink on the roulette table and shorted out the system. Our pit bosses have been alerted and are rushing to get the tables running again.
        </p>

        <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-danger btn-lg px-5 py-3 fw-bold rounded-pill shadow-sm">
            <i class="bi bi-arrow-counterclockwise me-2"></i> Back to the Casino Floor
        </a>

    </div>
</div>