@model IEnumerable<PokerTracker.ViewModels.Announcements.AnnouncementViewModel>
@{
    ViewData["Title"] = "Home Page";
}

<div class="text-white text-center py-5 mb-5 rounded-3 shadow-lg"
     style="background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('/images/poker-hero.jpg') center/cover no-repeat;">

    <div class="container py-5">
        <h1 class="display-3 fw-bold mb-3">Poker Night, Simplified.</h1>
        <p class="lead mb-5 mx-auto" style="max-width: 700px;">
            The easiest way to organize your private poker tournaments.
            Create events, manage players, and keep track of the action in one place.
        </p>

        <div class="d-flex justify-content-center gap-3">
            @if (User.Identity?.IsAuthenticated ?? false)
            {
                // LOGGED IN
                <a asp-controller="Tournament" asp-action="Index" class="btn btn-success btn-lg px-5 py-3 fw-bold shadow">
                    <i class="bi bi-play-circle-fill me-2"></i> Browse Games
                </a>
            }
            else
            {
                // NOT LOGGED IN
                <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary btn-lg px-5 py-3 fw-bold shadow">
                    <i class="bi bi-person-plus-fill me-2"></i> Create an account
                </a>
                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-light btn-lg px-5 py-3 fw-bold">
                    <i class="bi bi-box-arrow-in-right me-2"></i> Login
                </a>
            }
        </div>
    </div>
</div>

<div class="container mb-5">
    <div class="row g-4 text-center">

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm hover-effect">
                <div class="card-body p-4">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle d-inline-block mb-3">
                        <i class="bi bi-search fs-1 text-primary"></i>
                    </div>
                    <h3 class="h4 fw-bold">Find a Game</h3>
                    <p class="text-muted">
                        Browse the list of upcoming tournaments. Secure your seat at the table with one click.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm hover-effect">
                <div class="card-body p-4">
                    <div class="bg-success bg-opacity-10 p-3 rounded-circle d-inline-block mb-3">
                        <i class="bi bi-calendar-plus-fill fs-1 text-success"></i>
                    </div>
                    <h3 class="h4 fw-bold">Host & Organize</h3>
                    <p class="text-muted">
                        Be the tournament director. Set the date, choose the format (Texas Hold'em, Omaha, etc.), and manage your player list.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm hover-effect">
                <div class="card-body p-4">
                    <div class="bg-warning bg-opacity-10 p-3 rounded-circle d-inline-block mb-3">
                        <i class="bi bi-stopwatch-fill fs-1 text-warning"></i>
                    </div>
                    <h3 class="h4 fw-bold">Live Status</h3>
                    <p class="text-muted">
                        Know exactly what's happening. See which tournaments are Open for registration, currently Running, or recently Finished.
                    </p>
                </div>
            </div>
        </div>

    </div>
</div>

@if (Model != null && Model.Any())
{
    <div class="container mb-5">
        <div class="d-flex justify-content-between align-items-end mb-4 border-bottom border-warning pb-2">
            <h2 class="h3 fw-bold text-warning mb-0"><i class="bi bi-megaphone-fill me-2"></i> Latest Announcements</h2>
        </div>
        
        <div class="row g-4">
            @foreach (var announcement in Model.Take(3))
            {
                <div class="col-md-4">
                    <div class="card h-100 shadow border-0 hover-effect rounded-4 overflow-hidden" 
                         style="cursor: pointer; transition: transform 0.2s;" 
                         data-bs-toggle="modal" data-bs-target="#announcementModal-@announcement.Id">
                        
                        <div class="card-body p-4 bg-dark text-white">
                            <span class="badge bg-warning text-dark mb-3 px-3 py-2 rounded-pill">
                                <i class="bi bi-calendar-event me-1"></i> @announcement.PublishedOn.ToString("MMM dd, yyyy")
                            </span>
                            <h5 class="card-title fw-bold text-light mb-3">@announcement.Title</h5>
                            <p class="card-text text-white-50">
                                @(announcement.Content.Length > 100 ? announcement.Content.Substring(0, 100) + "..." : announcement.Content)
                            </p>
                        </div>
                        <div class="card-footer bg-dark border-top border-secondary pt-3 pb-4 px-4 text-end">
                            <span class="text-warning small fw-bold text-uppercase" style="letter-spacing: 1px;">Read More <i class="bi bi-arrow-right ms-1"></i></span>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="announcementModal-@announcement.Id" tabindex="-1" aria-labelledby="announcementModalLabel-@announcement.Id" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
                        <div class="modal-content bg-dark text-white border-secondary shadow-lg rounded-4">
                            <div class="modal-header border-secondary bg-gradient bg-warning text-dark">
                                <h5 class="modal-title fw-bold" id="announcementModalLabel-@announcement.Id">
                                    <i class="bi bi-megaphone-fill me-2 fs-5"></i>@announcement.Title
                                </h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            
                            <div class="modal-body p-4 p-md-5 text-start overflow-y-auto" style="max-height: 60vh;">
                                <p class="text-muted small mb-4 border-bottom border-secondary pb-3">
                                    <i class="bi bi-calendar-event me-2"></i>Published on @announcement.PublishedOn.ToString("MMMM dd, yyyy")
                                </p>
                                <div class="text-light opacity-75" style="white-space: pre-wrap; word-break: break-word; font-size: 1.1rem; line-height: 1.6;">@announcement.Content</div>
                            </div>
                            
                            <div class="modal-footer border-secondary">
                                <button type="button" class="btn btn-outline-secondary text-white rounded-pill px-4 fw-bold" data-bs-dismiss="modal">Close</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}
<div class="container py-3">
    <hr class="mt-0 mb-5 opacity-25">
            <div class="row align-items-center g-5">
                <div class="col-lg-6">
                    <h2 class="display-5 fw-bold lh-1 mb-4">Master Your <span class="text-warning">Tournament Entry</span></h2>
                    <p class="lead text-muted mb-4">
                        Our platform focuses on the logistics so you can focus on the cards. Easily manage who's at the table and track the progress of every event in your circle.
                    </p>
                    <ul class="list-unstyled">
                        <li class="mb-3 d-flex align-items-start">
                            <i class="bi bi-person-check-fill text-primary me-3 fs-5"></i>
                            <span><strong>Simplified Registration:</strong> Players can join tournaments with a single click, making headcount management effortless.</span>
                        </li>
                        <li class="mb-3 d-flex align-items-start">
                            <i class="bi bi-card-list text-primary me-3 fs-5"></i>
                            <span><strong>Clear Formats:</strong> Support for various poker styles—always know if you're playing Texas Hold'em, Omaha, or a custom variant.</span>
                        </li>
                        <li class="mb-3 d-flex align-items-start">
                            <i class="bi bi-shield-lock-fill text-primary me-3 fs-5"></i>
                            <span><strong>Secure Hosting:</strong> Only authorized organizers can manage the player list and update tournament outcomes.</span>
                        </li>
                    </ul>
                </div>
                <div class="col-lg-6">
                    <img src="~/images/poker-chips.jpg"
                         class="d-block mx-lg-auto img-fluid rounded-3 shadow-lg"
                         alt="Poker chips" loading="lazy">
                </div>
            </div>
        </div>

        <div class="text-white py-5 mt-5 shadow-lg"
             style="background: linear-gradient(rgba(0, 0, 0, 0.8), rgba(0, 0, 0, 0.8)),
            url('/images/gambling-mining.jpg') center/contain no-repeat;
            background-attachment: fixed;">

            <div class="container py-5">
                <div class="row justify-content-center text-center">
                    <div class="col-lg-8">
                        <h4 class="text-uppercase tracking-widest fw-bold text-warning-emphasis mb-0">Keep going</h4>

                        <i class="bi bi-quote text-warning display-1"></i>
                        <h2 class="fw-light fst-italic mb-4">
                            "Warning: Gambling involves a severe risk of extreme wealth."
                        </h2>
                        <p class="text-warning fw-bold fs-5">- The PokerTracker Team</p>
                    </div>
                </div>
            </div>
        </div>
</div>

        <div class="bg-light py-5">
            <div class="container text-center py-4">
                <h3 class="fw-bold mb-3">Ready to See Who's Playing?</h3>
                <p class="text-muted mb-4">Join the growing list of players and find your next seat at the table.</p>

                <div class="d-flex justify-content-center gap-3">
                    <a asp-controller="Tournament" asp-action="Index" class="btn btn-dark btn-lg px-5 fw-bold shadow-sm">
                        Browse Active Games
                    </a>
                    @if (!User.Identity?.IsAuthenticated ?? true)
                    {
                        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-outline-dark btn-lg px-5 fw-bold">
                            Join Now
                        </a>
                    }
                </div>
            </div>
        </div>

    </div>
</div>