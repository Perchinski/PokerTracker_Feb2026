@model PokerTracker.ViewModels.Tournaments.TournamentIndexViewModel

<div class="col">
    <div class="card h-100 shadow-sm border-0">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" class="card-img-top" alt="@Model.Name"
                 style="height: 200px; object-fit: cover;" onerror="this.onerror=null;this.src='/images/default-tournament.jpg';">
        }
        else
        {
            <img src="~/images/default-tournament.jpg" class="card-img-top" alt="Default Poker Image"
                 style="height: 200px; object-fit: cover;" asp-append-version="true">
        }

        @{
            string statusClass = Model.Status switch
            {
                "Open" => "bg-primary",
                "Running" => "bg-success",
                "Finished" => "bg-secondary",
                _ => "bg-secondary"
            };
        }

        <div class="card-header @statusClass text-white">
            <div class="d-flex justify-content-between align-items-center">
                <span class="badge bg-light text-dark">@Model.Format</span>
                <small class="fw-bold text-uppercase">@Model.Status</small>
            </div>
        </div>

        <div class="card-body">
            <h5 class="card-title text-truncate">@Model.Name</h5>
            <p class="card-text text-muted small">
                Organized by: <strong>@Model.Creator</strong>
            </p>
            <div class="mb-2">
                @if (Model.IsCreator)
                {
                    <span class="badge bg-warning text-dark me-1">
                        <i class="bi bi-star-fill me-1"></i>Your Tournament
                    </span>
                }
                @if (Model.IsJoined)
                {
                    <span class="badge bg-success">
                        <i class="bi bi-check-circle-fill me-1"></i>Joined
                    </span>
                }
            </div>

            <hr />

            <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <i class="bi bi-calendar-event me-2 text-primary"></i>
                    <span>@Model.Date.ToString(PokerTracker.GCommon.ApplicationConstants.Formatting.IndexDateFormat)</span>
                </div>
                <div class="text-muted small">
                    <i class="bi bi-people-fill me-1"></i> @Model.PlayersCount
                </div>
            </div>

            <div class="d-flex align-items-center mt-2 text-muted small">
                <i class="bi bi-geo-alt-fill me-2 text-danger"></i>
                <span class="text-truncate">@Model.LocationName, @Model.LocationCity</span>
            </div>
        </div>

        <div class="card-footer bg-white border-top-0 pb-3">
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-primary w-100">
                <i class="bi bi-eye"></i> View Details
            </a>
        </div>
    </div>
</div>