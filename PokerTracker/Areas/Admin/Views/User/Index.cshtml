@model IEnumerable<UserViewModel>

@{
    ViewData["Title"] = "User Management";
}

<partial name="_StatusMessages" />

<div class="container mt-4">
    <div class="mb-3">
        <a asp-action="Index" asp-controller="Home" class="btn btn-outline-secondary btn-sm fw-bold">
            <i class="bi bi-arrow-left"></i> Back to Admin Dashboard
        </a>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-warning"><i class="bi bi-people-fill me-2"></i>User Management</h2>
    </div>

    <div class="card bg-dark text-white border-secondary shadow">
        <div class="card-body p-0">
            <table class="table table-dark table-striped table-hover mb-0">
                <thead class="table-secondary">
                    <tr>
                        <th>Email / Username</th>
                        <th>Roles</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="align-middle">@user.Email</td>
                            <td class="align-middle">
                                @foreach (var role in user.Roles)
                                {
                                    var badgeColor = role == PokerTracker.GCommon.ApplicationConstants.Roles.Administrator ? "bg-danger" : "bg-primary";
                                    <span class="badge @badgeColor me-1">@role</span>
                                }
                            </td>
                            <td class="text-end align-middle">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="EditRoles" asp-route-id="@user.Id" class="btn btn-sm btn-outline-warning">
                                        Edit Roles
                                    </a>

                                    <form method="post" asp-action="Delete" asp-route-id="@user.Id" onsubmit="return confirm('Are you sure you want to delete this user?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>