@model PokerTracker.ViewModels.Announcements.AnnouncementViewModel

@{
    ViewData["Title"] = "Edit Announcement";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card bg-dark text-white border-secondary shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-gradient bg-warning text-dark py-3">
                    <h3 class="mb-0 fw-bold d-flex align-items-center">
                        <i class="bi bi-pencil-square me-2 fs-4"></i> Edit Announcement
                    </h3>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form method="post" asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold bg-dark p-2 rounded border border-danger"></div>
                        
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="PublishedOn" />

                        <div class="form-floating mb-4">
                            <input asp-for="Title" class="form-control bg-dark text-white border-secondary shadow-sm" placeholder="Title" />
                            <label asp-for="Title" class="text-muted"><i class="bi bi-type me-2"></i>Title</label>
                            <span asp-validation-for="Title" class="text-danger small mt-1 d-block fw-bold"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <textarea asp-for="Content" class="form-control bg-dark text-white border-secondary shadow-sm" placeholder="Content" style="height: 150px;"></textarea>
                            <label asp-for="Content" class="text-muted"><i class="bi bi-body-text me-2"></i>Content</label>
                            <span asp-validation-for="Content" class="text-danger small mt-1 d-block fw-bold"></span>
                        </div>

                        <div class="mb-4 bg-secondary bg-opacity-25 p-3 rounded-3 border border-secondary shadow-sm">
                            <div class="form-check form-switch ms-1 mt-1 fs-5 d-flex align-items-center gap-3">
                                <input class="form-check-input mt-0 fs-4 cursor-pointer" type="checkbox" asp-for="IsActive" role="switch" id="isActiveSwitch">
                                <label class="form-check-label text-light mb-0 cursor-pointer" for="isActiveSwitch">
                                    <i class="bi bi-eye-fill text-success me-1"></i> Visible
                                    <small class="d-block text-muted fs-6 mt-1"><i class="bi bi-info-circle me-1"></i>Turn off if announcement should be hidden from home page</small>
                                </label>
                            </div>
                        </div>

                        <div class="d-grid gap-3 d-md-flex justify-content-md-end mt-4 pt-3 border-top border-secondary">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 fw-bold shadow-sm rounded-pill py-2 text-uppercase letter-spacing-1">
                                <i class="bi bi-x-circle me-1"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-warning px-5 fw-bold shadow-sm rounded-pill py-2 text-uppercase letter-spacing-1 hover-lift">
                                <i class="bi bi-save me-1"></i> Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
